{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "outDir": "dist",
    "rootDir": "src",
    // Express handlers idiomatically `return res.json(...)` from guard clauses
    // and fall through at the end; that mix trips noImplicitReturns without any
    // real bug, so relax it for this package only.
    "noImplicitReturns": false,
    "types": ["node"]
  },
  "include": ["src"],
  "references": [
    {
      "path": "../../lib/db"
    },
    {
      "path": "../../lib/api-zod"
    }
  ]
}
